# Add these in Vercel Dashboard → Project → Settings → Environment Variables
# NEVER commit the real .env file or put API keys in frontend code

ANTHROPIC_API_KEY=your-anthropic-api-key-here
RESEND_API_KEY=your-resend-api-key-here
LEADS_EMAIL=your-email@example.com
FROM_EMAIL=Your Name <your@email.com>

# Upstash Redis → your database → REST API (copy both; local: .env.local, prod: Vercel env vars)
# Without these, /current-visitors uses in-memory store (ok for next dev, not for multi-user production).
UPSTASH_REDIS_REST_URL=https://xxxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-rest-token-here
